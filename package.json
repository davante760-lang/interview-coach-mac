{
  "name": "interview-coach-desktop",
  "version": "2.2.2",
  "description": "Captures system audio via ScreenCaptureKit and streams to Interview Coach",
  "main": "main.js",
  "scripts": {
    "start": "cp AudioCapture node_modules/electron/dist/Electron.app/Contents/MacOS/AudioCapture 2>/dev/null; electron .",
    "build-swift": "cd audio-capture && bash build.sh",
    "build": "electron-builder --mac",
    "release": "electron-builder --mac --publish always"
  },
  "author": "Interview Coach",
  "dependencies": {
    "electron-updater": "^6.8.3",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.interviewcoach.desktop",
    "productName": "Interview Coach Audio",
    "afterSign": "scripts/notarize.js",
    "files": [
      "main.js",
      "renderer.js",
      "index.html",
      "overlay.html",
      "trayTemplate.png"
    ],
    "protocols": [
      {
        "name": "Interview Coach",
        "schemes": [
          "interviewcoach"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns",
      "target": [
        "dmg",
        "zip"
      ],
      "identity": "736C27FD738A2E1AB02494C9096136C82BD6FB39",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "entitlements.mac.plist",
      "entitlementsInherit": "entitlements.mac.plist",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Interview Coach captures system audio for real-time transcription.",
        "NSScreenRecordingUsageDescription": "Interview Coach uses Screen Recording to capture system audio from your meetings."
      }
    },
    "extraFiles": [
      {
        "from": "AudioCapture",
        "to": "MacOS/AudioCapture"
      }
    ],
    "publish": {
      "provider": "github",
      "owner": "davante760-lang",
      "repo": "interview-coach-mac",
      "releaseType": "release"
    }
  }
}
